<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meriç Aytaş · Blog</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav>
        <a href="/" class="nav-brand">
            <div class="nav-logo">MA</div>
            <span class="nav-name">Meriç Aytaş</span>
        </a>
        <div>
            <a href="/">Anasayfa</a>
            <a href="/hakkimda">Hakkımda</a>
        </div>
    </nav>

    <div class="hero">
        <div class="hero-accent"></div>
        <div class="hero-particles" id="particles"></div>
        <div class="hero-content">
            <div class="hero-text">
                <div class="hero-tag">Kişisel Blog</div>
                <h1>Siber güvenlik ve<br><span>teknoloji</span> üzerine.</h1>
                <p>Siber güvenlik, teknoloji ve kod üzerine kişisel notlar. Öğrendiklerimi, keşfettiklerimi paylaşıyorum.</p>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-num"><%= yazilar.length %></div>
                        <div class="hero-stat-label">Yazı</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">16.03.2026</div>
                        <div class="hero-stat-label">Kuruluş</div>
                    </div>
                </div>
            </div>
            <div class="monitor">
                <div class="monitor-screen">
                    <div class="monitor-glow"></div>
                    <div class="monitor-dots">
                        <div class="monitor-dot" style="background:#ff5f57"></div>
                        <div class="monitor-dot" style="background:#febc2e"></div>
                        <div class="monitor-dot" style="background:#28c840"></div>
                    </div>
                    <div class="monitor-line"></div>
                    <div class="monitor-line short"></div>
                    <div class="monitor-line"></div>
                    <div class="monitor-line shorter"></div>
                    <div class="monitor-line short"></div>
                    <div class="monitor-line"></div>
                    <div class="monitor-line shorter"></div>
                </div>
                <div class="monitor-stand"></div>
                <div class="monitor-base"></div>
            </div>
        </div>
    </div>

    <div class="icerik">
        <p class="bolum-baslik">Son Yazılar</p>
        <% yazilar.forEach(yazi => { %>
            <div class="kart">
                <% if (yazi.resim) { %>
                    <img src="<%= yazi.resim %>" class="kart-resim" alt="<%= yazi.baslik %>">
                <% } else { %>
                    <div class="kart-resim-placeholder">Kapak resmi yok</div>
                <% } %>
                <div class="kart-body">
                    <h3><%= yazi.baslik %></h3>
                    <p class="tarih"><%= yazi.tarih %></p>
                    <p><%= yazi.kisaIcerik %></p>
                    <a href="/yazi/<%= yazi.id %>">Devamını oku →</a>
                </div>
            </div>
        <% }) %>
    </div>

    <footer>
        <span class="footer-left">Meriç Aytaş · Kişisel Blog</span>
        <span class="footer-right">© 2026 · Tüm hakları saklıdır.</span>
    </footer>

    <script>
        const container = document.getElementById('particles');
        for(let i = 0; i < 30; i++){
            const p = document.createElement('div');
            p.className = 'particle';
            const x = Math.random()*100, y = Math.random()*100;
            const tx = (Math.random()-0.5)*200, ty = (Math.random()-0.5)*200;
            const dur = (4 + Math.random()*6).toFixed(1)+'s';
            const delay = (Math.random()*6).toFixed(1)+'s';
            p.style.cssText = `left:${x}%;top:${y}%;--tx:${tx}px;--ty:${ty}px;--dur:${dur};animation-delay:${delay}`;
            container.appendChild(p);
        }
    </script>
</body>
</html>