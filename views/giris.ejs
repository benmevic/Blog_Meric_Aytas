<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarsLab - Giriş</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="giris-sayfa">
        <div class="giris-kutu">
            <h2 style="margin-bottom:16px;">Blog Benmevic</h2>
            <p style="font-size:13px;color:#999;margin-bottom:32px;">Admin paneline giriş yap</p>
            <% if (typeof hata !== 'undefined') { %>
                <p class="hata-mesaji"><%= hata %></p>
            <% } %>
            <form method="POST" action="/giris">
                <input type="text" name="kullanici" placeholder="Kullanıcı adı">
                <input type="password" name="sifre" placeholder="Şifre">
                <button type="submit">Giriş Yap</button>
            </form>
        </div>
    </div>
</body>
</html>