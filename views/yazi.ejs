<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meriç Aytaş · <%= yazi.baslik %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav>
        <a href="/" class="nav-brand">
            <div class="nav-logo">MA</div>
            <span class="nav-name">Meriç Aytaş Blog</span>
        </a>
        <div>
            <a href="/">Anasayfa</a>
            <a href="/hakkimda">Hakkımda</a>
        </div>
    </nav>

    <div class="hero">
        <div class="hero-accent"></div>
        <div class="hero-inner">
            <div class="hero-tag">Blog Yazısı</div>
            <h1><%= yazi.baslik %></h1>
            <p style="font-size:13px;color:#999;margin-top:8px;"><%= yazi.tarih %></p>
        </div>
    </div>

    <div class="icerik">
        <% if (yazi.resim) { %>
            <img src="<%= yazi.resim %>" class="yazi-resim" alt="<%= yazi.baslik %>">
        <% } %>
        <div class="admin-bolum">
            <p style="font-size:15px;color:#555;line-height:1.8;"><%= yazi.icerik %></p>
        </div>
        <a href="/" class="btn-duzenle" style="display:inline-block;margin-top:8px;padding:10px 20px;">← Geri Dön</a>
    </div>

    <footer>
        <span class="footer-left">Meriç Aytaş · Kişisel Blog</span>
        <span class="footer-right">© 2026 · Tüm hakları saklıdır.</span>
    </footer>
</body>
</html>