<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meriç Aytaş · Düzenle</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav>
        <a href="/" class="nav-brand">
            <div class="nav-logo">MA</div>
            <span class="nav-name">Meriç Aytaş</span>
        </a>
        <div>
            <a href="/admin">Admin</a>
            <a href="/cikis">Çıkış</a>
        </div>
    </nav>

    <div class="admin-icerik">
        <div class="admin-bolum">
            <h2>Yazıyı Düzenle</h2>
            <form method="POST" action="/admin/duzenle/<%= yazi.id %>" class="admin-form" enctype="multipart/form-data">
                <input type="text" name="baslik" value="<%= yazi.baslik %>" required>
                <input type="text" name="tarih" value="<%= yazi.tarih %>" required>
                <textarea name="icerik" rows="8" required><%= yazi.icerik %></textarea>
                <div style="margin-bottom:12px;">
                    <label style="font-size:13px;color:#666;display:block;margin-bottom:6px;">Kapak Resmi</label>
                    <% if (yazi.resim) { %>
                        <img src="<%= yazi.resim %>" style="width:100%;height:160px;object-fit:cover;border-radius:6px;margin-bottom:8px;">
                        <p style="font-size:12px;color:#555;margin-bottom:8px;">Yeni resim seçersen mevcut resim değişir.</p>
                    <% } %>
                    <input type="file" name="resim" accept="image/*">
                </div>
                <div style="display:flex;gap:10px;margin-top:4px;">
                    <button type="submit">Kaydet</button>
                    <a href="/admin" class="btn-duzenle" style="padding:10px 24px;font-size:14px;">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>

    <footer>
        <span class="footer-left">Meriç Aytaş · Admin Paneli</span>
        <span class="footer-right">© 2026 · Tüm hakları saklıdır.</span>
    </footer>
</body>
</html>
